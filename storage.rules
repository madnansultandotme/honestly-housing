rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasAccessToProject(projectId) {
      return projectId in getUserData().projectIds;
    }
    
    function isBuilder() {
      return isSignedIn() && getUserData().role == 'builder';
    }
    
    function belongsToBuilderOrg(orgId) {
      return isSignedIn() && getUserData().builderOrgId == orgId;
    }
    
    // Validate file size (max 10MB for images, 50MB for documents)
    function isValidImageSize() {
      return request.resource.size < 10 * 1024 * 1024;
    }
    
    function isValidDocumentSize() {
      return request.resource.size < 50 * 1024 * 1024;
    }
    
    // Validate image file types
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }
    
    function isDocument() {
      return request.resource.contentType.matches('application/pdf') ||
             request.resource.contentType.matches('application/msword') ||
             request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.*');
    }
    
    // Project photos
    match /projects/{projectId}/photos/{photoId} {
      allow read: if isSignedIn() && hasAccessToProject(projectId);
      
      allow write: if isSignedIn() && 
                      hasAccessToProject(projectId) && 
                      isImage() && 
                      isValidImageSize();
    }
    
    // Project photo thumbnails
    match /projects/{projectId}/photos/thumbnails/{photoId} {
      allow read: if isSignedIn() && hasAccessToProject(projectId);
      
      // Thumbnails are generated by Cloud Functions
      allow write: if false;
    }
    
    // Builder organization options (product images)
    match /options/{builderOrgId}/{optionId} {
      allow read: if isSignedIn();
      
      allow write: if isBuilder() && 
                      belongsToBuilderOrg(builderOrgId) && 
                      isImage() && 
                      isValidImageSize();
    }
    
    // Builder organization logos
    match /builderOrgs/{orgId}/logo.png {
      allow read: if isSignedIn();
      
      allow write: if isBuilder() && 
                      belongsToBuilderOrg(orgId) && 
                      isImage() && 
                      isValidImageSize();
    }
    
    // Message attachments
    match /messages/{projectId}/{messageId}/{attachmentId} {
      allow read: if isSignedIn() && hasAccessToProject(projectId);
      
      allow write: if isSignedIn() && 
                      hasAccessToProject(projectId) && 
                      ((isImage() && isValidImageSize()) || 
                       (isDocument() && isValidDocumentSize()));
    }
    
    // User profile photos (avatars)
    match /user_avatars/{fileName} {
      // Allow anyone to read avatars (public)
      allow read: if true;
      
      // Allow write if the filename starts with the user's ID (e.g., userId.jpg)
      allow write: if isSignedIn() && 
                      fileName.matches(request.auth.uid + '.*') &&
                      isImage() && 
                      isValidImageSize();
    }
    
    // User profile photos (optional feature - legacy)
    match /users/{userId}/profile.jpg {
      allow read: if isSignedIn();
      
      allow write: if isSignedIn() && 
                      request.auth.uid == userId && 
                      isImage() && 
                      isValidImageSize();
    }
    
    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
